{
  "id": "media.paged.sheet",
  "name": "paged.sheet",
  "version": "0.1.0",
  "apiVersion": "^0.2",
  "publisher": "paged.media",
  "capabilities": {
    "document": {
      "read": "broad",
      "write": "scoped"
    },
    "rendering": ["hitTest", "sceneLayer"],
    "network": false,
    "clipboard": "none",
    "storage": {
      "blob": true,
      "quotaBytes": 33554432
    },
    "wasm": [
      {
        "name": "sheet-engine",
        "path": "bin/sheet_js_bg.wasm",
        "purpose": "compute",
        "maxBytes": 8388608
      }
    ]
  },
  "contributes": {
    "panels": [
      "media.paged.sheet.panel.workbook",
      "media.paged.sheet.panel.grid"
    ],
    "commands": [
      "media.paged.sheet.command.importXlsx",
      "media.paged.sheet.command.lowerToFrame",
      "media.paged.sheet.command.lowerChartToFrame",
      "media.paged.sheet.command.openGrid",
      "media.paged.sheet.command.showGridInFrame",
      "media.paged.sheet.command.hideGridInFrame"
    ],
    "importers": [
      "media.paged.sheet.importer.xlsx"
    ],
    "exporters": [
      "media.paged.sheet.exporter.xlsx"
    ],
    "editContexts": [
      { "type": "sheet", "entry": "doubleClick" }
    ],
    "objectTypes": [
      { "type": "sheetFrame", "bakedFallback": "rectangle" }
    ]
  }
}
